{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://partnr-p3rv.onrender.com/api/:path*"
    },
    {
      "source": "/hubs/:path*",
      "destination": "https://partnr-p3rv.onrender.com/hubs/:path*"
    },
    {
      "source": "/((?!api|hubs).*)",
      "destination": "/index.html"
    }
  ]
}
